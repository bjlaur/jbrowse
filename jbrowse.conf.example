# jbrowse.conf.example
#
# Copy this to jbrowse.conf and edit it.
# Do not commit your real jbrowse.conf; it contains your Jellyfin password.

[jellyfin]
url = http://127.0.0.1:8096
username = your-login
password = your-password

[library]
# Comma-separated Jellyfin item types to load.
types = Movie,Episode,Video,MusicVideo

[ui]
# Sort mode can be:
#   added     = recently added
#   played    = last played
#   premiere  = premiere date
#   name      = name
#   series    = series order
sort_mode = added

# true = descending / down arrow
# false = ascending / up arrow
sort_desc = true

# 0 means unlimited. Any positive number caps how many matched items are rendered.
max_display_items = 0

# title or filename
display_mode = title

[style]
# Optional. Relative paths are relative to this jbrowse.conf file.
# Use {script} to refer to the directory containing jbrowse.py.
# path = themes/03-jbrowse-batman-low-contrast.tcss
# path = {script}/themes/03-jbrowse-batman-low-contrast.tcss

[mpv]
# Optional. Commands are parsed with shell-like quoting.
# $subtitle and $start are omitted when they do not apply.
# Supported placeholders: $url, $filename, $title, $subtitle, $start.
# mpv_cmd = mpv --hwdec=auto --force-media-title="$filename" $subtitle $start "$url"

[cache]
# 0 disables periodic refresh. Positive values refresh in the background
# while jbrowse has been active in the last 10 minutes.
refresh_interval_minutes = 10

[playback]
# Quality presets for Ctrl+B cycling. "direct" = no transcoding.
# Others use Jellyfin transcoding with MaxStreamingBitrate.
quality_presets = direct,40mbps,20mbps,12mbps,8mbps,4mbps,2mbps
default_quality = direct
