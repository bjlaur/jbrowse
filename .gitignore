# jbrowse local runtime files
#
# These are files jbrowse looks for next to the script/executable,
# but they should not be committed.

# Real config: contains Jellyfin URL/login/password.
# Commit jbrowse.conf.example instead.
jbrowse.conf

# Local device id / state.
jbrowse.state

# Local library cache: can contain private media names/paths.
jbrowse.items.json
jbrowse.items.json.tmp

# Local style override. Commit named theme files under themes/ instead.
jbrowse.tcss

# Local screenshot harvests: can contain private media names.
screenshot/

# Temporary source/output files used while generating the committed fake fixture.
tools/batches/
tools/fake_cache_data.json
tools/fake_cache_data_merged.json
tools/validation_report.json

# Python local build/cache noise.
__pycache__/
*.py[cod]

*.zip
